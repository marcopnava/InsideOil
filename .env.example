# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/insideoil

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Email
RESEND_API_KEY=

# ─── Real-time data feeds ───────────────────────────────────

# AISStream — global AIS WebSocket. Free signup at https://aisstream.io/
# Required by `workers/ais-worker.ts` (long-lived Node process; deploy to Railway/Fly).
AISSTREAM_API_KEY=

# OpenSky Network — OAuth2 client credentials.
# Create at https://opensky-network.org/  → Profile → API Client.
# 4000 credits/day default. Each /states/all call (no bbox) ≈ 4 credits.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Vercel cron protection (must match Authorization header from cron requests)
CRON_SECRET=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
